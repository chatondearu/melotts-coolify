# MeloTTS Git source (build-time). No official ghcr.io image — see Dockerfile.
MELOTTS_REPO=https://github.com/myshell-ai/MeloTTS.git
MELOTTS_REF=main
# Tag applied to the built image (override when pushing to a registry from Coolify).
MELOTTS_IMAGE=melotts-coolify:local

# PyTorch wheel index at image build time (Compose build arg). Default CPU wheels avoid
# CUDA dependency explosions and failed/timeout builds on modest builders (e.g. Coolify).
# GPU example: https://download.pytorch.org/whl/cu121 — only if your builder/runtime supports it.
TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu

# Docker Compose service name (container_name)
SERVICE_NAME=melotts

# Traefik router hostname when not using Coolify magic vars: ${TRAEFIK_SUBDOMAIN}.${DOMAIN} (e.g. tts.example.com).
# On Coolify, add SERVICE_FQDN_MELOTTS to the service env (empty value) and set the service domain in the UI to https://your-host:8888 — see docs/coolify.md
TRAEFIK_SUBDOMAIN=tts
DOMAIN=example.com

# Host port published when using docker-compose.local.yml (container stays on 8888)
HOST_PORT=8888

# Host path bound to /app/output in the container (audio files on your server)
OUTPUT_HOST_DIR=./output

# In-container output directory (consumed by the MeloTTS app)
OUTPUT_DIR=/app/output

# REQUIRED for docker-compose.yml (Coolify): Traefik Basic Auth in front of Gradio.
# Generate: docker run --rm httpd:2.4-alpine htpasswd -nbB myuser 'your-strong-password'
# In .env, double every $ in the hash (e.g. $2y$ → $$2y$$). See docs/access-control.md
#
# Example below is ciuser / citest — REPLACE in production.
TRAEFIK_BASIC_AUTH_USERS=ciuser:$$apr1$$qZ2lDl9/$$Yj5X2.Zpp9aGEO1HANtHi/
